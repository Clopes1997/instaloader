{
  "manifest_version": 3,
  "name": "Instaloader",
  "version": "3.0",
  "description": "Download images & videos from any webpage. Filter by type and size, save all as a ZIP, or grab individual files.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
