{
  "manifest_version": 3,
  "name": "Instaloader",
  "version": "3.0",
  "description": "Easily download images from any website. Click the extension icon to see all images on the current page.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
